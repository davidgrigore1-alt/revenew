# Supabase. Leave empty for the safe local demo fallback used by CI builds.
# Real values belong only in an ignored .env.local file or an approved secret store.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Server-only. Never expose through NEXT_PUBLIC_* or client code.
SUPABASE_SERVICE_ROLE_KEY=

# Optional providers. The application keeps local fallbacks when they are absent.
OPENAI_API_KEY=
OPENAI_MODEL=
RESEND_API_KEY=

# Access mode: "preview" lets authenticated internal testers choose an allowlisted
# preview plan without payment. "paid" enforces server-verified subscriptions.
# Missing or invalid values fail safe to "paid" in production and "preview" locally.
REVENEW_ACCESS_MODE=preview

# Usage metering mode: off, observe, enforce.
# Use observe until the additive usage migration is applied and verified.
REVENEW_USAGE_MODE=observe

# Public canonical site URL used for sitemap and metadata. No secret value.
REVENEW_PUBLIC_SITE_URL=https://revenew.ro